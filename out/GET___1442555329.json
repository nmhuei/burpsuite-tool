")};\n\t        renderCallback(obj);\n\t        //alert(intervalStart.format(\"YYYY-MM-DD\") + \":\" + intervalEnd.format(\"YYYY-MM-DD\"));\n\t\t},\n\t\teventRender: function(event, element) {\n\t\t    if (event.showWarning === 'true') {\n\t\t        var newElement = $('<div id=\"imagePanel\" class=\"\"><img src=\"/images/warning-event.png\" class=\"event-icon\" /></div>');\n\t\t        element.append(newElement);\n\t\t        newElement.find('.event-icon').on('mouseenter', function(event) {\n\t\t            event.stopPropagation(); // NgÄn cháº·n sá»± kiá»n lan truyá»n lÃªn phÃ­a trÃªn\n\t\t            $('.tooltipevent').remove();\n\t\t            newElement.append('<div class=\"tooltip-content\">Lá»ch táº¡m thá»i</div>');\n\t\t        });\n\t\t        newElement.find('.event-icon').on('mouseleave', function() {\n\t\t            $('.tooltipevent').remove();\n\t\t            newElement.find('.tooltip-content').remove();\n\t\t        });\n\t\t    }\n\t\t},\n\t\teventMouseover: function(calEvent, jsEvent) {\n\t\t\tvar obj = {\"id\": calEvent.taskId};\n\t\t\t//mouseOverCallback(obj);\n \t\t    var tooltip = '<div class=\"tooltipevent\" style=\"width:300px;height:250px;background:#7fffd4;position:absolute;z-index:10001;\">' + calEvent.tooltip + '</div>';\n\t\t    $(\"body\").append(tooltip);\n\t\t    $(this).mouseover(function(e) {\n\t\t        $(this).css('z-index', 10000);\n\t\t        $('.tooltipevent').fadeIn('500');\n\t\t        $('.tooltipevent').fadeTo('10', 1.9);\n\t\t    }).mousemove(function(e) {\n\t\t        $('.tooltipevent').css('top', e.pageY + 10);\n\t\t        $('.tooltipevent').css('left', e.pageX + 20);\n\t\t    });\n\t\t},\n\t\teventMouseout: function(calEvent, jsEvent) {\n\t\t\tvar obj = {\"id\": calEvent.taskId};\n\t\t\t//mouseOutCallback(obj);\n \t\t     $(this).css('z-index', 8);\n\t\t     $('.tooltipevent').remove();\n\t\t},\n\t\teventLimit : 2, // allow \"more\" link when too many events\n\t\tviews : {\n\t\t\tlistDay : {\n\t\t\t\tbuttonText