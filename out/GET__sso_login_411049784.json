t\t\t\t\t<input class=\"input-field\" type=\"text\" id=\"username\" name=\"username\"\n\t\t\t\t\t\t\t\t\t\t\t\tplaceholder=\"Nháº­p tÃªn tÃ i khoáº£n\" required>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t<div class=\"input-group\">\n\t\t\t\t\t\t\t\t\t\t\t<label class=\"input-label\" for=\"password\">Máº­t kháº©u <span\n\t\t\t\t\t\t\t\t\t\t\t\t\tstyle=\"color:#d32d2f\">*</span></label>\n\t\t\t\t\t\t\t\t\t\t\t<input class=\"input-field\" type=\"password\" id=\"password\" name=\"password\"\n\t\t\t\t\t\t\t\t\t\t\t\tplaceholder=\"Nháº­p máº­t kháº©u\" required>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t<div style=\"display: flex; justify-content: end;\"><a href=\"/sso/forgot-password\" class=\"forgot-link\">QuÃªn máº­t kháº©u?</a>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t<div class=\"captcha-box\">\n\t\t\t\t\t\t\t\t\t\t\t\t<div class=\"g-recaptcha\" data-sitekey=\"6Le0tncrAAAAAH_Y2P80S-Wv6vnHr5CXX97n7CYP\"\n\t\t\t\t\t\t\t\t\t\t\t\t\tdata-callback=\"enableSubmitButton\"></div>\n\t\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<button id=\"btnLogin\" class=\"login-btn\"  disabled='true'>ÄÄng nháº­p</button>\n\t\t\t\t\t\t\t\t\t</form>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\t\t\t<div id=\"dropDownSelect1\"></div>\n\n\t\t\t<!--===============================================================================================-->\n\t\t\t<script src=\"/sso/vendor/jquery/jquery-3.2.1.min.js\"></script>\n\t\t\t<!--===============================================================================================-->\n\t\t\t<script src=\"/sso/vendor/animsition/js/animsition.min.js\"></script>\n\t\t\t<!--===============================================================================================-->\n\t\t\t<script src=\"/sso/vendor/bootstrap/js/popper.js\"></script>\n\t\t\t<script src=\"/sso/vendor/bootstrap/js/bootstrap.min.js\"></script>\n\t\t\t<!--=======================================