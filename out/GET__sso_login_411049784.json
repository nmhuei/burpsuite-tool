se;\n\t\t\t\t\tcolor: #111827;\n\t\t\t\t\tbackground: #fff;\n\t\t\t\t\tbox-sizing: border-box;\n\t\t\t\t}\n\n\t\t\t\t.input-field:focus {\n\t\t\t\t\tborder: 2px solid #DC2626;\n\t\t\t\t\tbox-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);\n\t\t\t\t\toutline: none;\n\t\t\t\t}\n\n\t\t\t\t.forgot-link {\n\t\t\t\t\tdisplay: block;\n\t\t\t\t\ttext-align: right;\n\t\t\t\t\tfont-size: 13px;\n\t\t\t\t\tcolor: #6B7280;\n\t\t\t\t\tmargin-bottom: 20px;\n\t\t\t\t\ttext-decoration: none;\n\t\t\t\t\tfont-style: italic;\n\t\t\t\t}\n\n\t\t\t\t.forgot-link:hover {\n\t\t\t\t\ttext-decoration: underline;\n\t\t\t\t\tcolor: #DC2626;\n\t\t\t\t}\n\n\t\t\t\t.captcha-box {\n\t\t\t\t\tmargin: 0 auto 20px auto;\n\t\t\t\t\tdisplay: flex;\n\t\t\t\t\tjustify-content: center;\n\t\t\t\t\theight: 78px;\n\t\t\t\t}\n\n\t\t\t\t.login-btn {\n\t\t\t\t\twidth: 100%;\n\t\t\t\t\tborder-radius: 24px;\n\t\t\t\t\tbackground: #DC2626;\n\t\t\t\t\tcolor: #fff;\n\t\t\t\t\tfont-size: 16px;\n\t\t\t\t\tfont-weight: 500;\n\t\t\t\t\theight: 48px;\n\t\t\t\t\tborder: none;\n\t\t\t\t\tcursor: pointer;\n\t\t\t\t\tmargin-top: 0;\n\t\t\t\t\ttransition: background 0.2s;\n\t\t\t\t}\n\n\t\t\t\t.login-btn:disabled {\n\t\t\t\t\tbackground: #E5E7EB;\n\t\t\t\t\tcolor: #aaa;\n\t\t\t\t\tcursor: not-allowed;\n\t\t\t\t}\n\n\t\t\t\t.alert-danger {\n\t\t\t\t\tbackground: linear-gradient(135deg, #fff5f5 0%, #fef2f2 100%);\n\t\t\t\t\tcolor: #dc2626;\n\t\t\t\t\tborder: 1px solid #fecaca;\n\t\t\t\t\tborder-radius: 12px;\n\t\t\t\t\tpadding: 12px 16px;\n\t\t\t\t\tmargin-bottom: 16px;\n\t\t\t\t\tfont-size: 14px;\n\t\t\t\t\ttext-align: center;\n\t\t\t\t\tbox-shadow: 0 2px 8px rgba(220, 38, 38, 0.08);\n\t\t\t\t\tposition: relative;\n\t\t\t\t\tanimation: fadeInUp 0.4s ease-out;\n\t\t\t\t\tfont-weight: 400;\n\t\t\t\t\tline-height: 1.5;\n\t\t\t\t}\n\n\t\t\t\t.alert-danger::before {\n\t\t\t\t\tcontent: \"â ï¸\";\n\t\t\t\t\tmargin-right: 8px;\n\t\t\t\t\tfont-size: 16px;\n\t\t\t\t}\n\n\t\t\t\t@keyframes fadeInUp {\n\t\t\t\t\tfrom {\n\t\t\t\t\t\topacity: 0